# Doxygen configuration for cmake_windows_sample

PROJECT_NAME           = "cmake_windows_sample"
PROJECT_BRIEF          = "CMake C++ sample project"
OUTPUT_DIRECTORY       = out/docs
CREATE_SUBDIRS         = NO

OUTPUT_LANGUAGE        = Japanese
USE_MDFILE_AS_MAINPAGE = README.md
MARKDOWN_SUPPORT       = YES

INPUT                  = include \
                         src \
                         libs/core/include \
                         libs/core/src
FILE_PATTERNS          = *.h *.hpp *.c *.cc *.cpp *.md
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */out/* */vcpkg/* */tests/*

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = YES
MULTILINE_CPP_IS_BRIEF = YES

WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO
QUIET                  = NO

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_TREEVIEW      = YES

GENERATE_LATEX         = NO
GENERATE_XML           = NO

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = .

HAVE_DOT               = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
CLASS_DIAGRAMS         = YES
DOT_IMAGE_FORMAT       = svg
DOT_MULTI_TARGETS      = YES
DOT_NUM_THREADS        = 4
