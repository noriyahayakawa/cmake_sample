{
  "version": "0.2.0",
  "configurations": [
    // -----------------------------------------------------------------------
    // [Windows] clang-cl
    // -----------------------------------------------------------------------
    {
      "name": "[Windows] Debug app (clang-cl Debug)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/out/build/clangcl-debug-static/app.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "console": "integratedTerminal",
      "preLaunchTask": "[Windows] CMake: ビルド (clang-cl Debug)"
    },
    {
      "name": "[Windows] Debug tests (clang-cl Debug)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/out/build/clangcl-debug-static/tests/tests.exe",
      "args": ["--gtest_filter=*"],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "console": "integratedTerminal",
      "preLaunchTask": "[Windows] CMake: ビルド (clang-cl Debug)"
    },
    // -----------------------------------------------------------------------
