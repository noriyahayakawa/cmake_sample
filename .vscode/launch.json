    // -----------------------------------------------------------------------
    // [WSL Ubuntu-24.04] clang
    // -----------------------------------------------------------------------
    {
      "name": "[WSL Ubuntu-24.04] Debug app (clang Debug)",
      "type": "cppdbg",
      "request": "launch",
      "program": "/home/hayak/work/cmake_sample/out/build/clang-debug/app",
      "args": [],
      "stopAtEntry": false,
      "cwd": "/home/hayak/work/cmake_sample",
      "environment": [],
      "externalConsole": false,
      "pipeTransport": {
        "pipeCwd": "${workspaceFolder}",
        "pipeProgram": "wsl",
        "pipeArgs": ["-d", "Ubuntu-24.04", "--"],
        "debuggerPath": "/usr/bin/gdb"
      },
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "[WSL Ubuntu-24.04] CMake: ビルド (clang Debug)"
    },
    {
      "name": "[WSL Ubuntu-24.04] Debug tests (clang Debug)",
      "type": "cppdbg",
      "request": "launch",
      "program": "/home/hayak/work/cmake_sample/out/build/clang-debug/tests/tests",
      "args": ["--gtest_filter=*"],
      "stopAtEntry": false,
      "cwd": "/home/hayak/work/cmake_sample",
      "environment": [],
      "externalConsole": false,
      "pipeTransport": {
        "pipeCwd": "${workspaceFolder}",
        "pipeProgram": "wsl",
        "pipeArgs": ["-d", "Ubuntu-24.04", "--"],
        "debuggerPath": "/usr/bin/gdb"
      },
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "[WSL Ubuntu-24.04] CMake: ビルド (clang Debug)"
    }
  ]
