{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: 構成 (clang-cl Debug)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--preset",
        "clangcl-debug"
      ],
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "CMake: 構成 (clang-cl Release)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--preset",
        "clangcl-release"
      ],
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "CMake: ビルド (clang-cl Debug)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "clangcl-debug"
      ],
      "problemMatcher": [
        "$msCompile"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "CMake: ビルド (clang-cl Release)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "clangcl-release"
      ],
      "problemMatcher": [
        "$msCompile"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
