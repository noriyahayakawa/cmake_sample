        "--preset",
        "msvc-debug"
      ],
      "problemMatcher": []
    },
    {
      "label": "CMake: 構成 (MSVC Release)",
      "type": "shell",
      "command": "${workspaceFolder}/tools/cmake-msvc-x64.cmd",
      "args": [
        "--preset",
        "msvc-release"
      ],
      "problemMatcher": []
    },
    {
      "label": "CMake: ビルド (MSVC Debug)",
      "type": "shell",
      "command": "${workspaceFolder}/tools/cmake-msvc-x64.cmd",
      "args": [
        "--build",
        "--preset",
        "msvc-debug"
      ],
      "problemMatcher": [
        "$msCompile"
      ],
      "group": "build"
    },
    {
      "label": "CMake: ビルド (MSVC Release)",
      "type": "shell",
