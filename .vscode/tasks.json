        "--build",
        "--preset",
        "msvc-release"
      ],
      "problemMatcher": [
        "$msCompile"
      ],
      "group": "build"
    },
    {
      "label": "CMake: clang-tidy (clang-cl Debug)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "clangcl-debug-tidy"
      ],
      "problemMatcher": [
        "$msCompile"
      ],
      "group": "test"
    },
    {
      "label": "CMake: clang-format",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "format"
      ],
      "problemMatcher": [],
      "group": "none"
    },
    {
      "label": "CTest: run tests (clang-cl Debug)",
      "type": "shell",
      "command": "ctest",
      "args": [
        "--preset",
        "clangcl-debug"
